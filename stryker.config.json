{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/api/schema/stryker-core.json",
  "testRunner": "tap",
  "tap": {
    "testFiles": ["packages/*/dist/*.test.js"],
    "nodeArgs": ["--experimental-test-module-mocks"],
    "forceBail": false
  },
  "mutate": ["packages/*/dist/**/*.js", "!packages/*/dist/**/*.test.js", "!packages/*/dist/bundle.js"],
  "coverageAnalysis": "perTest",
  "timeoutMS": 10000,
  "concurrency": 2,
  "reporters": ["clear-text", "progress"],
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": true
}
