{
  "name": "evomcp",
  "version": "0.3.1",
  "description": "Evolutionary MCP server — cheap-model fanout (best-of-N + repair chains) and scalar-fitness evolution, gated by dod-guard verification. Keeps token-burning out of the agent's main context.",
  "type": "module",
  "main": "dist/bundle.js",
  "bin": {
    "evomcp": "dist/bundle.js"
  },
  "files": [
    "dist/bundle.js",
    "agents/",
    "scripts/",
    "skills/",
    ".claude-plugin/plugin.json",
    ".mcp.json"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --experimental-test-module-mocks --test \"dist/*.test.js\"",
    "bundle": "node esbuild.config.mjs",
    "prepublishOnly": "npm run build && npm run bundle",
    "start": "node dist/bundle.js",
    "coverage": "c8 --include=\"dist/*.js\" --exclude=\"dist/*.test.js\" --reporter=text --reporter=html node --experimental-test-module-mocks --test \"dist/*.test.js\"",
    "dev": "tsc --watch"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "mcp",
    "evolution",
    "best-of-n",
    "deepseek",
    "optimization"
  ],
  "author": "tychohenzen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TychoHenzen/dod-guard.git",
    "directory": "packages/evomcp"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0"
  }
}
