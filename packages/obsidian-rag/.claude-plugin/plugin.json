{
  "name": "obsidian-rag",
  "description": "RAG/memory MCP server on an Obsidian vault. Semantic search, note CRUD, memory recall, backlink traversal — all local, all offline.",
  "author": {
    "name": "tychohenzen",
    "url": "https://github.com/tychohenzen"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/bootstrap-deps.js\"",
            "timeout": 65,
            "statusMessage": "obsidian-rag: checking dependencies..."
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/inject-memories.js\"",
            "timeout": 10,
            "statusMessage": "obsidian-rag: injecting memories..."
          }
        ]
      }
    ]
  }
}
