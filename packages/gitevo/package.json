{
  "name": "gitevo",
  "version": "0.3.2",
  "description": "Evolutionary git branching for LLM agents — checkpoint, spawn, learn, abandon, adopt, finish. Ported from Python GitEvoMCP to TypeScript.",
  "type": "module",
  "main": "dist/bundle.js",
  "bin": {
    "gitevo": "dist/bundle.js"
  },
  "files": [
    "dist/bundle.js",
    "scripts/",
    ".claude-plugin/plugin.json",
    ".mcp.json"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --experimental-test-module-mocks --test \"dist/*.test.js\"",
    "test:integration": "tsc && node --experimental-test-module-mocks --test \"dist/operations.test.js\"",
    "bundle": "node esbuild.config.mjs",
    "prepublishOnly": "npm run build && npm run bundle",
    "start": "node dist/bundle.js",
    "coverage": "c8 --include=\"src/*.ts\" --exclude=\"src/*.test.ts\" --reporter=text --reporter=html node --experimental-test-module-mocks --test \"dist/*.test.js\"",
    "dev": "tsc --watch"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "mcp",
    "git",
    "evolution",
    "branching",
    "checkpoint",
    "lessons-learned"
  ],
  "author": "tychohenzen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TychoHenzen/dod-guard.git",
    "directory": "packages/gitevo"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0"
  }
}
